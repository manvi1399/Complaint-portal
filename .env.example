# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Optional local ports for the split citizen and admin portals.
PORT="3000"
ADMIN_PORT="3001"

# Optional seeded admin credentials for the separate admin portal.
ADMIN_SEED_USERNAME="admin@chandigarh.gov.in"
ADMIN_SEED_PASSWORD="Admin@123"

# --- OTP by email ---
# If SMTP and Resend are both unset/empty, local development uses demo mode:
# OTP is shown in the UI only (no email). For real emails, set SMTP (below) OR RESEND_API_KEY.

# Gmail example (App Password, not your normal password — uncomment and fill):
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-16-character-app-password"
# OTP_FROM_EMAIL="Complaint Portal <your-email@gmail.com>"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
OTP_FROM_EMAIL="Complaint Portal <onboarding@resend.dev>"

# Resend: https://resend.com — API key + verified sending domain (or their sandbox rules).
# If both SMTP and Resend are configured, SMTP is used first.
RESEND_API_KEY=""

# Optional. "true" forces OTP to appear in API/UI even when email is configured (avoid in production).
# In development, demo preview turns on automatically when no SMTP/Resend is set.
OTP_DEMO_PREVIEW=""

# Real database persistence.
# Use MongoDB Atlas, local MongoDB, or a managed MongoDB connection string.
# If omitted in local development, the app falls back to data/*.json.
MONGODB_URI=""
MONGODB_DB_NAME="complaint_portal"

# Basic auth abuse protection. Attempts are counted per IP and identifier.
LOGIN_RATE_LIMIT="10"
OTP_RATE_LIMIT="5"
